// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTITUTE_ADMIN
  SUPER_ADMIN
}

enum PlanType {
  FREE
  MONTHLY
  YEARLY
  LIFETIME
}

// ... rest of the file ...
